{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "desktop-debug",
      "displayName": "Desktop (Debug)",
      "description": "Debug build with tests enabled",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "desktop-release",
      "displayName": "Desktop (Release)",
      "description": "Release build with tests enabled",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "ci",
      "displayName": "CI build",
      "description": "Release build with tests and strict compiler warnings",
      "inherits": "desktop-release",
      "binaryDir": "${sourceDir}/build/ci"
    }
  ],
  "buildPresets": [
    {
      "name": "desktop-debug",
      "configurePreset": "desktop-debug",
      "jobs": 0
    },
    {
      "name": "desktop-release",
      "configurePreset": "desktop-release",
      "jobs": 0
    },
    {
      "name": "ci",
      "configurePreset": "ci",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "desktop-debug",
      "configurePreset": "desktop-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop-release",
      "configurePreset": "desktop-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci",
      "configurePreset": "ci",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
